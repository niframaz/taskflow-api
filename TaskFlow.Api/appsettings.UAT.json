{
  "Serilog": {
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "%HOME%\\LogFiles\\TaskFlowApi\\uat-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] ({MachineName}/{ThreadId}) {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Application": "TaskFlow API (UAT)"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=UAT_SERVER;Database=TaskFlowUAT;User Id=UAT_USER;Password=UAT_PASSWORD;"
  },
  "AppSettings": {
    "TempPath": "%HOME%\\Temp"
  }
}