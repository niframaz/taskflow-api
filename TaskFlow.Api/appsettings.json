{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProcessId",
      "WithProcessName",
      "WithExceptionDetails",
      "WithCorrelationId"
    ],
    "Properties": {
      "Application": "TaskFlow API"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "h5jc8-UH&$H-hu&G%-867yU-mhcGt-JGH76-tsgjh",
    "Issuer": "TaskFlow",
    "Audience": "MyAppUsers",
    "ExpirationInMinutes": 600
  },
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "IdentitySettings": {
    "Password": {
      "RequireDigit": true,
      "RequiredLength": 8,
      "RequireNonAlphanumeric": true,
      "RequireUppercase": true,
      "RequireLowercase": true
    }
  },
  "CacheSettings": {
    "UserCacheExpirationMinutes": 5,
    "MembershipCacheExpirationMinutes": 1
  },
  "DatabaseSettings": {
    "EnableInitializationOnStartup": false
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "*/users/login",
        "Period": "5m",
        "Limit": 5
      },
      {
        "Endpoint": "*/users/register",
        "Period": "1h",
        "Limit": 3
      }
    ]
  }
}