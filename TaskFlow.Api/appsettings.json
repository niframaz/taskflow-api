{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Exceptions",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread",
      "Serilog.Enrichers.Process"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProcessId",
      "WithProcessName"
    ],
    "Properties": {
      "Application": "TaskFlow API"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "h5jc8-UH&$H-hu&G%-867yU-mhcGt-JGH76-tsgjh",
    "Issuer": "TaskFlow",
    "Audience": "MyAppUsers",
    "ExpirationInMinutes": 600
  }
}